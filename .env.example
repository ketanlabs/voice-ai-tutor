# =============================================================================
# Voice AI Spanish Tutor — environment template
# Copy to `.env` (`cp .env.example .env`) and fill in the values.
# ALL services read config from this single file at the project root.
# Nothing is hardcoded in source. Never commit your real `.env`.
# =============================================================================

# ------------------------------------------------------------------ LiveKit ---
# Self-hosted (default): these dev keys are used by the in-compose LiveKit
# server (livekit/livekit.yaml) AND by the backend to mint access tokens.
# For LiveKit Cloud instead: create a project at https://cloud.livekit.io,
# then set LIVEKIT_API_KEY/SECRET from the project and point the URLs at
# wss://<your-project>.livekit.cloud .
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=<your-secret-key-here>

# URL the VOICE agent (inside Docker) uses to reach the LiveKit server.
LIVEKIT_URL=ws://livekit:7880
# URL the BROWSER uses to reach the LiveKit server (from the host).
# Self-hosted: ws://localhost:7880 . Cloud: wss://<project>.livekit.cloud .
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ------------------------------------------------------------ Service wiring ---
# Internal URL the frontend/voice use to reach the backend API (compose DNS).
BACKEND_URL=http://backend:8000
# Browser-facing backend URL (host). Frontend calls this for tokens.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# Redis connection (backend only — the sole owner of Redis).
REDIS_URL=redis://redis:6379/0

# --------------------------------------------------------- Model providers ----
# USE_LIVEKIT_INFERENCE=true routes STT/LLM/TTS through LiveKit Cloud Inference
# (single LiveKit key, no provider accounts). false = self-hosted "bring your
# own keys" pipeline using the direct plugins below.
USE_LIVEKIT_INFERENCE=false

# Which provider each stage uses (only relevant when USE_LIVEKIT_INFERENCE=false)
STT_PROVIDER=openai
LLM_PROVIDER=anthropic         # anthropic
TTS_PROVIDER=openai

# Provider API keys (fill the ones matching the providers you selected above).
# Deepgram STT — https://console.deepgram.com
DEEPGRAM_API_KEY=
# Anthropic Claude LLM — https://console.anthropic.com
ANTHROPIC_API_KEY=<enter-anthropic-key-here>
# Cartesia TTS — https://play.cartesia.ai
CARTESIA_API_KEY=
# Optional alternative TTS providers
ELEVENLABS_API_KEY=
OPENAI_API_KEY=<enter-openai-key-here>

# ---------------------------------------------------- Model / voice tuning ----
# LLM model id (Anthropic). claude-sonnet-5 is the low-latency default;
# claude-opus-4-8 is stronger but slower/costlier.
LLM_MODEL=claude-sonnet-5
# STT model (Deepgram). nova-3 supports multilingual es/en code-switching.
STT_MODEL=gpt-4o-mini-transcribe
# TTS model + a Spanish-capable voice id for the chosen TTS provider.
# Leave TTS_VOICE_ID blank to use the provider's default voice (TTS still
# speaks Spanish because language is set from TARGET_LANG).
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE_ID=ash

# ------------------------------------------------------------- Tutor config ---
TARGET_LANG=es                 # language being taught
NATIVE_LANG=en                 # learner's native language (for scaffolding)
DEFAULT_CEFR_LEVEL=A2          # starting level for brand-new learners
